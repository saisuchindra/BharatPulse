# ── Server Environment Variables ──
# Copy this to server/.env and fill in your keys

PORT=4000
NODE_ENV=development

# Set this to your deployed client URL on Render (e.g. https://bharatpulse-client.onrender.com)
CLIENT_URL=

# API Keys
MAPBOX_TOKEN=
NEWS_API_KEY=
OPENWEATHER_API_KEY=
ALPHA_VANTAGE_KEY=
AQICN_API_KEY=

# Optional
REDIS_URL=
DATABASE_URL=
